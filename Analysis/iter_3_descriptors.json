{
  "iteration": 3,
  "descriptors": [
    {
      "id": "d1",
      "name": "grain size",
      "physical_meaning": "average grain diameter",
      "units": "micrometers",
      "rationale": "single length scale characterizing microstructure",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "commonly measured via linear intercept method"
      }
    },
    {
      "id": "d2",
      "name": "grain size distribution",
      "physical_meaning": "spread in grain diameters",
      "units": "dimensionless or micrometers",
      "rationale": "statistical descriptor of microstructural heterogeneity",
      "representation": {
        "type": "finite_vector",
        "encoding": "histogram bins or moments",
        "dimension": "2-20",
        "notes": "often mean and standard deviation suffice"
      }
    },
    {
      "id": "d3",
      "name": "grain aspect ratio",
      "physical_meaning": "grain length to width ratio",
      "units": "dimensionless",
      "rationale": "quantifies grain elongation and anisotropy",
      "representation": {
        "type": "scalar",
        "encoding": "real value greater than one",
        "dimension": "1",
        "notes": "unity indicates equiaxed grains"
      }
    },
    {
      "id": "d4",
      "name": "grain boundary area per volume",
      "physical_meaning": "total boundary area normalized by volume",
      "units": "inverse micrometers",
      "rationale": "relates to interface energy and diffusion",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "scales inversely with grain size"
      }
    },
    {
      "id": "d5",
      "name": "texture strength",
      "physical_meaning": "degree of crystallographic preferred orientation",
      "units": "dimensionless",
      "rationale": "affects anisotropic mechanical and physical properties",
      "representation": {
        "type": "scalar",
        "encoding": "texture index or ODF entropy",
        "dimension": "1",
        "notes": "random texture gives unity for index"
      }
    },
    {
      "id": "d6",
      "name": "twin boundary fraction",
      "physical_meaning": "proportion of twin boundaries",
      "units": "dimensionless fraction",
      "rationale": "special boundaries with distinct properties",
      "representation": {
        "type": "scalar",
        "encoding": "real value between zero and one",
        "dimension": "1",
        "notes": "commonly sigma-3 boundaries in FCC"
      }
    },
    {
      "id": "d7",
      "name": "high angle boundary fraction",
      "physical_meaning": "fraction of boundaries above 15 degrees",
      "units": "dimensionless fraction",
      "rationale": "distinguishes general from low angle boundaries",
      "representation": {
        "type": "scalar",
        "encoding": "real value between zero and one",
        "dimension": "1",
        "notes": "threshold commonly fifteen degrees"
      }
    },
    {
      "id": "d8",
      "name": "grain boundary energy",
      "physical_meaning": "average boundary energy per unit area",
      "units": "joules per square meter",
      "rationale": "thermodynamic driving force for grain growth",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "averaged over boundary character distribution"
      }
    },
    {
      "id": "d9",
      "name": "dislocation density",
      "physical_meaning": "total dislocation line length per volume",
      "units": "per square meter",
      "rationale": "measures crystal defect concentration and strain",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "increases with plastic deformation"
      }
    },
    {
      "id": "d10",
      "name": "grain boundary character distribution",
      "physical_meaning": "frequency of boundary types and misorientations",
      "units": "dimensionless",
      "rationale": "complete statistical description of boundary ensemble",
      "representation": {
        "type": "finite_vector",
        "encoding": "histogram over misorientation space",
        "dimension": "10-100",
        "notes": "discretized five parameter distribution"
      }
    },
    {
      "id": "d11",
      "name": "grain boundary misorientation angle",
      "physical_meaning": "average crystallographic misorientation across boundaries",
      "units": "degrees",
      "rationale": "characterizes typical boundary character",
      "representation": {
        "type": "scalar",
        "encoding": "real value between zero and sixty-two",
        "dimension": "1",
        "notes": "maximum depends on crystal symmetry"
      }
    },
    {
      "id": "d12",
      "name": "grain orientation spread",
      "physical_meaning": "internal misorientation within individual grains",
      "units": "degrees",
      "rationale": "indicates intragranular deformation and substructure",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "quantifies local lattice curvature"
      }
    },
    {
      "id": "d13",
      "name": "triple junction density",
      "physical_meaning": "number of triple junctions per area",
      "units": "per square micrometer",
      "rationale": "topological measure of network connectivity",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "relates to grain boundary network"
      }
    },
    {
      "id": "d14",
      "name": "grain topology",
      "physical_meaning": "number of neighbors per grain",
      "units": "dimensionless count",
      "rationale": "defines grain connectivity and network structure",
      "representation": {
        "type": "finite_vector",
        "encoding": "distribution or average neighbor count",
        "dimension": "1-10",
        "notes": "average near six for 2D sections"
      }
    },
    {
      "id": "d15",
      "name": "subgrain size",
      "physical_meaning": "average subgrain or cell diameter",
      "units": "micrometers",
      "rationale": "finer scale structure within grains",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "smaller than grain size"
      }
    },
    {
      "id": "d16",
      "name": "stored elastic energy",
      "physical_meaning": "elastic energy from dislocations and boundaries",
      "units": "joules per cubic meter",
      "rationale": "drives recrystallization and recovery processes",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "sum of dislocation and interface contributions"
      }
    },
    {
      "id": "d17",
      "name": "grain boundary mobility",
      "physical_meaning": "velocity per unit driving force",
      "units": "meters per joule second",
      "rationale": "kinetic parameter controlling microstructure evolution",
      "representation": {
        "type": "scalar",
        "encoding": "real positive value",
        "dimension": "1",
        "notes": "temperature and character dependent"
      }
    },
    {
      "id": "d18",
      "name": "grain boundary tortuosity",
      "physical_meaning": "boundary path length to straight distance",
      "units": "dimensionless ratio",
      "rationale": "measures boundary roughness and meandering",
      "representation": {
        "type": "scalar",
        "encoding": "real value greater than one",
        "dimension": "1",
        "notes": "unity for perfectly straight boundaries"
      }
    },
    {
      "id": "d19",
      "name": "grain shape factor",
      "physical_meaning": "deviation from ideal equiaxed grain shape",
      "units": "dimensionless",
      "rationale": "quantifies shape regularity and isotropy",
      "representation": {
        "type": "scalar",
        "encoding": "circularity or sphericity measure",
        "dimension": "1",
        "notes": "various definitions like circularity ratio"
      }
    },
    {
      "id": "d20",
      "name": "recrystallized fraction",
      "physical_meaning": "volume fraction of recrystallized grains",
      "units": "dimensionless fraction",
      "rationale": "tracks microstructure transformation during annealing",
      "representation": {
        "type": "scalar",
        "encoding": "real value between zero and one",
        "dimension": "1",
        "notes": "zero deformed to one fully recrystallized"
      }
    },
    {
      "id": "d21",
      "name": "grain boundary segregation",
      "physical_meaning": "solute concentration at grain boundaries",
      "units": "atomic fraction or molar",
      "rationale": "affects boundary properties and mechanical behavior",
      "representation": {
        "type": "scalar",
        "encoding": "real positive concentration value",
        "dimension": "1",
        "notes": "enrichment relative to bulk composition"
      }
    }
  ]
}